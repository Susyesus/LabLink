# ==========================================
# LabLink Master .gitignore
# ==========================================

# --- Maven & Build Outputs (Backend) ---
**/target/
**/*.class
**/*.jar
**/*.war
**/*.nar
**/*.ear
**/*.zip
**/*.tar.gz
**/*.rar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
.flattened-pom.xml
.m2/
.mvn/wrapper/maven-wrapper.jar

# --- Node / React (Frontend) ---
**/node_modules/
**/dist/
**/build/
.eslintcache
*.tsbuildinfo

# --- IDE & System Files ---
.vscode/
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
bin/
out/
.factorypath
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Environment & Secrets (CRITICAL) ---
# Prevents leaking your Supabase/JWT credentials
.env
.env.example
.env.local
.env.*.local
application-*.properties
application.properties
*.p12
*.pem
*.jks

# --- Database / Supabase Specific ---
.supabase/
supabase/.temp/